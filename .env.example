# Application
APP_NAME="Institutional DeFi Platform API"
ENVIRONMENT=local
DEBUG=true

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/institutional_defi

# Redis
REDIS_URL=redis://localhost:6379/0

# Telemetry
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_TRACING=false
ENABLE_METRICS=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# Decoder (LLM)
# ANTHROPIC_API_KEY=

# Blockchain RPCs
# ETHEREUM_RPC_URL=
# POLYGON_RPC_URL=
# ARBITRUM_RPC_URL=
# OPTIMISM_RPC_URL=
# BASE_RPC_URL=
# AVALANCHE_RPC_URL=

# Feature flags
ENABLE_FEATURE_STORE=false
ENABLE_DECODER_SERVICE=false
ENABLE_JPM_SCENARIOS=false

# Temporal (workflows)
# TEMPORAL_HOST=localhost:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=regulatory-workflows
